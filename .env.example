# Kimi Open Platform API keys can use:
# AI_BASE_URL=https://api.moonshot.cn/v1
# AI_MODEL=moonshot-v1-8k
# Note: Kimi Coding Plan / Kimi Code keys are restricted to coding agents and are not suitable for this custom game app.
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.moonshot.cn/v1
AI_MODEL=moonshot-v1-8k
AI_REQUEST_TIMEOUT_MS=12000
AI_CHAT_MAX_TOKENS=64
AI_VISIBLE_OUTPUT_MAX_TOKENS=220
